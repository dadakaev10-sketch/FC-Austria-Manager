rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profiles - users can only write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // Clubs
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // All other collections - any authenticated user can CRUD
    // Data isolation is enforced via clubId filtering on the client
    match /teams/{docId} {
      allow read, write: if request.auth != null;
    }
    match /players/{docId} {
      allow read, write: if request.auth != null;
    }
    match /player_teams/{docId} {
      allow read, write: if request.auth != null;
    }
    match /player_stats/{docId} {
      allow read, write: if request.auth != null;
    }
    match /trainings/{docId} {
      allow read, write: if request.auth != null;
    }
    match /training_attendance/{docId} {
      allow read, write: if request.auth != null;
    }
    match /matches/{docId} {
      allow read, write: if request.auth != null;
    }
    match /match_events/{docId} {
      allow read, write: if request.auth != null;
    }
    match /announcements/{docId} {
      allow read, write: if request.auth != null;
    }
    match /calendar_events/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
